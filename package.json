{
  "name": "ezra-bid-assistant",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "shared",
    "backend",
    "extension"
  ],
  "scripts": {
    "build": "bun run --filter '@ezra/backend' build && bun run --filter '@ezra/extension' build",
    "dev:backend": "bun run --filter '@ezra/backend' dev",
    "dev:extension": "bun run --filter '@ezra/extension' dev",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check --write --unsafe .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2"
  }
}
